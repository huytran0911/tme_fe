    "/client/v1/categories": {
      "get": {
        "tags": [
          "Client Categories"
        ],
        "summary": "Get category tree for client",
        "description": "Returns the hierarchical category tree structure:\r\n- Level 1: Category Groups (from group table)\r\n- Level 2+: Categories and Subcategories (nested structure from products_category table)\r\n\r\nEach category can have multiple child categories, forming a tree.",
        "operationId": "Client_GetCategories",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CategoryGroupResponseIReadOnlyListApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/client/v1/products": {
      "get": {
        "tags": [
          "Client Products"
        ],
        "summary": "Get product list for client with paging/filter/sort",
        "description": "Returns paged list of products for client facing site.\r\n        \r\nQuery Parameters:\r\n- keyword: Search in code, name, nameEn (optional)\r\n- categoryId: Filter by category (optional)\r\n- page: Page number starting from 1 (default: 1)\r\n- pageSize: Items per page, max 100 (default: 20)\r\n- sortBy: Sort field - name|price|date (default: sort order)\r\n- sortDir: Sort direction - asc|desc (default: desc)",
        "operationId": "Client_GetProducts",
        "parameters": [
          {
            "name": "Keyword",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "CategoryId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "Page",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "PageSize",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "SortBy",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "SortDir",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductListItemResponsePagedResultApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/client/v1/products/by-group": {
      "get": {
        "tags": [
          "Client Products"
        ],
        "summary": "Get products by group ID with paging",
        "description": "Returns a paged list of products that belong to the given group via products_category and products_cats mapping.\r\n\r\nLogic:\r\n1. Find all categories (products_category) that belong to this group\r\n2. Find all products linked to these categories via products_cats\r\n3. Return distinct products with paging and sorting\r\n\r\nQuery Parameters:\r\n- groupId: Group ID (required)\r\n- page: Page number starting from 1 (default: 1)\r\n- pageSize: Items per page, max 100 (default: 20)\r\n- sortBy: Sort field - name|price|date (default: date desc)\r\n- sortDir: Sort direction - asc|desc (default: desc)",
        "operationId": "Client_GetProductsByGroup",
        "parameters": [
          {
            "name": "GroupId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "Page",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "PageSize",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "SortBy",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "SortDir",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductListItemResponsePagedResultApiResponse"
                }
              }
            }
          }
        }
      }
    },
