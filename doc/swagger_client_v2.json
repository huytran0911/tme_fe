    "/client/v1/contents/{code}": {
      "get": {
        "tags": [
          "Client - Content Pages"
        ],
        "summary": "Get content page by code and language",
        "description": "Returns a single content page for the given code and language.\r\n\r\nLanguage parameter:\r\n- 'vi' or 'vn' ? returns Vietnamese content\r\n- 'en' ? returns English content\r\n- If not specified ? defaults to Vietnamese\r\n- If requested language not found and was 'en' ? fallback to 'vn'\r\n\r\nExamples:\r\n- /client/v1/contents/about_us?lang=vi\r\n- /client/v1/contents/about_us?lang=en\r\n- /client/v1/contents/contact_info (defaults to vi)",
        "operationId": "Client_GetContentByCode",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentPageDetailResponseApiResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentPageDetailResponseApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/client/v1/contents/menu": {
      "get": {
        "tags": [
          "Client - Content Pages"
        ],
        "summary": "Get menu content pages",
        "description": "Returns the list of content pages that should be displayed in client menu (OnMenu = true).\r\n\r\nQuery Parameters:\r\n- language: Language code (e.g., 'vn', 'en')\r\n\r\nOrdered by Code ascending.",
        "operationId": "Client_GetMenuContents",
        "parameters": [
          {
            "name": "language",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentPageListItemResponseIReadOnlyListApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/client/v1/news": {
      "get": {
        "tags": [
          "Client - News"
        ],
        "summary": "Get published news list for client",
        "description": "Returns paged list of published news (Status = 1) for client.\r\n\r\nQuery Parameters:\r\n- typeNews: Filter by news type (optional)\r\n- page: Page number starting from 1 (default: 1)\r\n- pageSize: Items per page, max 100 (default: 20)\r\n\r\nOrdered by DateAdded descending (newest first).",
        "operationId": "Client_GetNewsList",
        "parameters": [
          {
            "name": "typeNews",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewsListItemResponsePagedResultApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/client/v1/news/{id}": {
      "get": {
        "tags": [
          "Client - News"
        ],
        "summary": "Get published news detail for client",
        "description": "Returns detail of a published news item. Returns 404 if not found or not published.",
        "operationId": "Client_GetNewsDetail",
